<!DOCTYPE html>
<html>
<head>
    <title>#{title}</title>
    <meta charset="utf-8" />
</head>
<body>
      
    <h1>#{title} в Pug</h1>
      
    if emailsVisible
        <h3>Emails</h3>
        <ul>
            each email in emails
                <li>#{email}</li>
        </ul>
    else
        <h3>Emails not visible</h3>
    <p>Phone: #{phone}</p>
</body>
<html>
